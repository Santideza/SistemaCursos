@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-7">
        <div class="card border-danger shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 text-danger">Acceso denegado</h1>
                <p class="mb-3">
                    No tienes permisos para ingresar a esta sección. Si necesitas acceso al panel de coordinación, solicita el rol correspondiente.
                </p>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al inicio</a>
                    <a asp-controller="Cursos" asp-action="Index" class="btn btn-outline-secondary">Ir al catálogo</a>
                </div>
            </div>
        </div>
    </div>
</div>
